<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/textViewAdminTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Panel"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage users, events, and reservations."
            android:textSize="16sp"
            android:textColor="#444444"
            android:gravity="center"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Menu"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="30dp" />

        <Button
            android:id="@+id/buttonManageUsers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage Users"
            android:layout_marginTop="15dp" />

        <Button
            android:id="@+id/buttonAddAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Admin"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/buttonManageEvents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage Events"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/buttonViewReservations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Reservations"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/buttonAdminLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:layout_marginTop="20dp" />

    </LinearLayout>

</ScrollView>
